---
import linkedinIcon from "../assets/linkedin-icon.svg";
import gitHubIcon from "../assets/github-icon.svg";
---

<main
  id="main-content"
  class="flex-auto mx-auto max-w-[720px] w-full px-4 py-8"
>
  <!-- Name & Title -->
  <section class="flex flex-col gap-1 mb-6">
    <h1 class="font-serif font-bold text-4xl text-[#e8e8e8]">Gleb Golov</h1>
    <p class="font-sans text-xl text-[#a0a0b0]">Web Developer</p>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Profile photo placeholder -->
  <div class="flex justify-center mb-6">
    <div
      class="w-24 h-24 rounded-full bg-[#16213e] flex items-center justify-center text-[#e8e8e8] text-2xl font-serif font-bold"
    >
      GG
    </div>
  </div>

  <!-- Bio -->
  <section class="mb-6">
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">About</h2>
    <p class="text-base text-[#e8e8e8] leading-relaxed mb-3">
      Full-stack web developer with experience building modern web applications
      from concept to deployment. Skilled in JavaScript, TypeScript, and the
      React ecosystem, with a strong foundation in backend systems, databases,
      and DevOps practices.
    </p>
    <p class="text-base text-[#e8e8e8] leading-relaxed mb-3">
      Passionate about clean architecture, maintainable code, and delivering
      intuitive user experiences. Comfortable working across the full stack—
      from designing RESTful APIs and database schemas to crafting responsive
      component-based UIs.
    </p>
    <p class="text-base text-[#e8e8e8] leading-relaxed mb-3">
      Approach every project with a focus on quality, collaboration, and
      continuous learning. Experienced in agile environments and
      cross-functional teams where communication and adaptability drive results.
    </p>
    <p class="font-sans text-sm text-[#a0a0b0]">Turin, Italy</p>

    <!-- Languages -->
    <h3 class="font-serif font-semibold text-lg text-[#e8e8e8] mt-4 mb-2">
      Languages
    </h3>
    <div class="flex flex-wrap gap-2">
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >English</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Italian</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Russian</span
      >
    </div>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Skills -->
  <section class="mb-6">
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">Skills</h2>

    <h3 class="font-serif font-semibold text-lg text-[#e8e8e8] mb-3">
      Frontend
    </h3>
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >React</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >TypeScript</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Next.js</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Astro</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Tailwind CSS</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >HTML/CSS</span
      >
    </div>

    <h3 class="font-serif font-semibold text-lg text-[#e8e8e8] mb-3">
      Backend
    </h3>
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Node.js</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Express</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Python</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >PostgreSQL</span
      >
    </div>

    <h3 class="font-serif font-semibold text-lg text-[#e8e8e8] mb-3">
      Tools &amp; DevOps
    </h3>
    <div class="flex flex-wrap gap-2 mb-6">
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Git</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Docker</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >GitHub Actions</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >VS Code</span
      >
      <span class="px-3 py-1 text-sm bg-[#16213e] text-[#a0a0b0] rounded-full"
        >Linux</span
      >
    </div>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Experience -->
  <section class="flex flex-col gap-1 mb-6">
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">
      Experience
    </h2>
    <ol class="flex flex-col gap-6">
      <li>
        <section>
          <h3 class="font-serif font-semibold text-lg text-[#e8e8e8]">
            Web Developer
          </h3>
          <p class="font-sans text-sm text-[#a0a0b0]">Capgemini — Full Time</p>
          <p class="font-sans text-sm text-[#a0a0b0]">
            Oct 2022 — Present · Turin, Italy (Hybrid)
          </p>
        </section>
      </li>
      <li>
        <section>
          <h3 class="font-serif font-semibold text-lg text-[#e8e8e8]">
            Q.A. Developer
          </h3>
          <p class="font-sans text-sm text-[#a0a0b0]">EpiCura — Full Time</p>
          <p class="font-sans text-sm text-[#a0a0b0]">
            Oct 2022 — Present · Turin, Italy (Hybrid)
          </p>
        </section>
      </li>
    </ol>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Education -->
  <section class="mb-6">
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">Education</h2>

    <div class="mb-4">
      <h3 class="font-serif font-semibold text-lg text-[#e8e8e8]">
        Master's Degree in Computer Science
      </h3>
      <p class="font-sans text-sm text-[#a0a0b0]">University Name</p>
      <p class="font-sans text-sm text-[#a0a0b0]">2020 — 2022</p>
    </div>

    <div class="mb-4">
      <h3 class="font-serif font-semibold text-lg text-[#e8e8e8]">
        Bachelor's Degree in Computer Science
      </h3>
      <p class="font-sans text-sm text-[#a0a0b0]">University Name</p>
      <p class="font-sans text-sm text-[#a0a0b0]">2016 — 2020</p>
    </div>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Contact -->
  <section>
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">Contact</h2>
    <ul class="flex flex-col gap-3">
      <li>
        <a
          href="https://www.linkedin.com/in/gleb-golov/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-row items-center gap-2 text-[#4a90d9] hover:text-[#6bb3f0]"
        >
          <img src={linkedinIcon.src} width="24" height="24" alt="" />
          LinkedIn
        </a>
      </li>
      <li>
        <a
          href="https://github.com/GGolov"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-row items-center gap-2 text-[#4a90d9] hover:text-[#6bb3f0]"
        >
          <img src={gitHubIcon.src} width="24" height="24" alt="" />
          GitHub
        </a>
      </li>
    </ul>
  </section>
</main>
