---
import linkedinIcon from "../assets/linkedin-icon.svg";
import gitHubIcon from "../assets/github-icon.svg";
---

<main class="flex-auto mx-auto max-w-[720px] w-full px-4 py-8">
  <!-- Name & Title -->
  <section class="flex flex-col gap-1 mb-6">
    <h1 class="font-serif font-bold text-4xl text-[#e8e8e8]">Gleb Golov</h1>
    <p class="font-sans text-xl text-[#a0a0b0]">Web Developer</p>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Professional Summary -->
  <section class="mb-6">
    <p class="text-base text-[#e8e8e8] leading-relaxed">
      Web developer with experience building modern web applications. Passionate
      about clean code, user experience, and continuous learning.
    </p>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Experience -->
  <section class="flex flex-col gap-1 mb-6">
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">
      Experience
    </h2>
    <ol class="flex flex-col gap-6">
      <li>
        <section>
          <h3 class="font-serif font-semibold text-lg text-[#e8e8e8]">
            Web Developer
          </h3>
          <p class="font-sans text-sm text-[#a0a0b0]">Capgemini — Full Time</p>
          <p class="font-sans text-sm text-[#a0a0b0]">
            Oct 2022 — Present · Turin, Italy (Hybrid)
          </p>
        </section>
      </li>
      <li>
        <section>
          <h3 class="font-serif font-semibold text-lg text-[#e8e8e8]">
            Q.A. Developer
          </h3>
          <p class="font-sans text-sm text-[#a0a0b0]">EpiCura — Full Time</p>
          <p class="font-sans text-sm text-[#a0a0b0]">
            Oct 2022 — Present · Turin, Italy (Hybrid)
          </p>
        </section>
      </li>
    </ol>
  </section>

  <hr class="border-[#2a2a3e] mb-6" />

  <!-- Contact -->
  <section>
    <h2 class="font-serif font-bold text-2xl text-[#e8e8e8] mb-4">Contact</h2>
    <ul class="flex flex-col gap-3">
      <li>
        <a
          href="https://www.linkedin.com/in/gleb-golov/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-row items-center gap-2 text-[#4a90d9] hover:text-[#6bb3f0]"
        >
          <img src={linkedinIcon.src} width="24" height="24" alt="" />
          LinkedIn
        </a>
      </li>
      <li>
        <a
          href="https://github.com/GGolov"
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-row items-center gap-2 text-[#4a90d9] hover:text-[#6bb3f0]"
        >
          <img src={gitHubIcon.src} width="24" height="24" alt="" />
          GitHub
        </a>
      </li>
    </ul>
  </section>
</main>

<style></style>
